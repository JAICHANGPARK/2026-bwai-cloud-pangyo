# -----------------------------------------------------------------------------
# Gemma 4 Hands-On Environment Variables Template
# Copy this file to '.env' in the same directory and adjust values as needed.
# -----------------------------------------------------------------------------

# 1. 로컬 LLM 프로바이더 선택 ('ollama' | 'lmstudio' | 'llamacpp')
LLM_PROVIDER=ollama

# 2. 호출할 Gemma 4 모델명 지정
# - Ollama 예시: gemma4:e4b
# - LM Studio 예시: google/gemma-4-e2b (또는 불러온 모델 ID)
# - llama.cpp 예시: gemma-4 (또는 기동 중인 모델 ID)
LLM_MODEL=gemma4:e4b

# 3. 로컬 API 서버 주소 설정 (주석 해제 후 수정하여 사용)
# - 코드 내부에서 빈 값일 경우 아래의 각 프로바이더별 디폴트 주소로 자동 매핑됩니다.
#   * Ollama 기본: http://localhost:11434
#   * LM Studio 기본: http://localhost:1234/v1
#   * llama.cpp 기본: http://localhost:8080/v1
LLM_API_URL=http://localhost:11434
